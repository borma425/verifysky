{
  "name": "edge-shield",
  "version": "1.0.0",
  "description": "Ultimate Edge Shield — Enterprise-Grade Zero-Trust Bot Protection on Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build:slider": "node scripts/build-slider.mjs",
    "build": "wrangler deploy --dry-run --outdir dist",
    "prebuild": "npm run build:slider",
    "deploy": "wrangler deploy && npm run purge:cache",
    "predeploy": "npm run build:slider",
    "purge:cache": "node scripts/purge-cache.mjs",
    "db:init": "wrangler d1 execute EDGE_SHIELD_DB --file=./schema.sql",
    "db:init:local": "wrangler d1 execute EDGE_SHIELD_DB --local --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "javascript-obfuscator": "^4.1.1",
    "typescript": "^5.6.0",
    "wrangler": "^4.73.0"
  }
}
