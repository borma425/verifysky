+            return ['ok' => false, 'error' => $query['error'], 'synced' => []];
+        }
+
+        $synced = [];
+        $errors = [];
+        foreach ($query['rows'] as $row) {
+            if (! is_array($row)) {
+                continue;
+            }
+            $domain = trim((string) ($row['domain_name'] ?? ''));
+            $zoneId = trim((string) ($row['zone_id'] ?? ''));
+            if ($domain === '' || $zoneId === '') {
