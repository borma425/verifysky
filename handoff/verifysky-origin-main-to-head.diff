+            'granted_plan_key' => 'pro',
+            'source' => 'manual',
+            'status' => TenantPlanGrant::STATUS_ACTIVE,
+            'starts_at' => '2026-05-10 00:00:00',
+            'ends_at' => '2026-05-15 00:00:00',
+        ]);
+
+        $this->artisan('billing:reconcile-expired-plan-grants', ['--now' => '2026-05-16 00:00:00'])
