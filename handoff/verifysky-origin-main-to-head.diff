+use App\Services\EdgeShield\D1DatabaseClient;
+
+class PlanLimitsService
+{
+    private const EXTRA_DOMAIN_ALLOWANCE_SETTING_KEYS = [
+        'extra_domains',
+        'bonus_domains',
+        'extra_domain_slots',
+        'bonus_domain_slots',
