+        $this->assertStringContainsString("domain_name = 'example.com'", $joinedSql);
+        $this->assertStringContainsString("domain_name = 'www.example.com'", $joinedSql);
+        $this->assertStringNotContainsString('other.com', $joinedSql);
+    }
