-                    str_replace("'", "''", $newDesc),
-                    (int)$rule['id']
-                );
-                $this->queryD1($sql);
-            }
-        }
-
-        if ($totalRemoved > 0) {
-            $this->purgeCustomFirewallRulesCache('global');
-        }
-
-        return ['ok' => true, 'removed' => $totalRemoved];
-    }
