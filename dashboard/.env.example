APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# This file is a local/staging starter template.
# Production must override APP_ENV=production, APP_DEBUG=false,
# SESSION_SECURE_COOKIE=true, and all Cloudflare/PayPal resources with
# production-specific Worker, D1, KV, zone, and webhook values.

# Admin login hardening
DASHBOARD_ADMIN_USER=replace_with_secure_admin_user
DASHBOARD_ADMIN_PASS=replace_with_long_random_password
DASHBOARD_LOGIN_PATH=wow/login
SEED_ADMIN_EMAIL=admin@verifysky.com
SEED_ADMIN_PASSWORD=replace_with_local_admin_password
SEED_USER_EMAIL=user@verifysky.com
SEED_USER_PASSWORD=replace_with_local_user_password

# Worker project / Wrangler access from dashboard host
EDGE_SHIELD_ROOT=/opt/lampp/htdocs/verifysky/worker
NODE_BIN_DIR=/opt/lampp/htdocs/verifysky/dashboard/.runtime/node-v22.22.1/bin
WRANGLER_BIN="/opt/lampp/htdocs/verifysky/dashboard/.runtime/node-v22.22.1/bin/npx wrangler"
# Use "local" for Dashboard-to-Wrangler D1 testing without Cloudflare API calls.
EDGE_SHIELD_TARGET_ENV=staging
EDGE_SHIELD_D1_MODE=remote
D1_DATABASE_NAME=VERIFY_SKY_STAGING_DB_V2
D1_DATABASE_ID=57656d70-8d1a-4fff-b38b-fe705303bac1
EDGE_SHIELD_D1_LOCAL_PERSIST_PATH=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
EDGE_SHIELD_D1_READ_CACHE_TTL=60
EDGE_SHIELD_D1_ALLOW_WRANGLER_REMOTE=false
CLOUDFLARE_KV_NAMESPACE_ID=230e5e4702d24cf8b84abd0c6dddad43
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=verifysky.com
SAAS_CNAME_TARGET=customers.verifysky.com
EDGE_SHIELD_WORKER_NAME=verifysky-edge-staging

# Worker runtime values synced by the admin platform settings screen.
# In production, these values are sourced from this environment only.
OPENROUTER_MODEL=
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_API_KEY=
JWT_SECRET=
METER_SECRET=
ES_ADMIN_TOKEN=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_BRAND_NAME=VerifySky
PAYPAL_PLAN_ID_GROWTH=
PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_BUSINESS=
PAYPAL_PLAN_ID_SCALE=
ES_TURNSTILE_STRICT=on
ES_STRICT_CONTEXT_BINDING=off
ES_ADMIN_ALLOWED_IPS=
ES_ADMIN_RATE_LIMIT_PER_MIN=60
ES_BLOCK_REDIRECT_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edge_shield_CF
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=90
REDIS_QUEUE=default

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local: log or smtp/Mailtrap. Production: resend
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
RESEND_KEY=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
